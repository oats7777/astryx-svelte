{
  "name": "@astryxdesign/svelte-vega",
  "version": "0.0.0",
  "private": true,
  "description": "Private Svelte Vega wrapper surface for Astryx.",
  "author": "Meta Open Source",
  "license": "MIT",
  "type": "module",
  "astryx": {
    "_comment": "Private Svelte Vega package. Keep private: true as the hard guarantee against accidental publish until an explicit release decision changes it."
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./VegaChart.svelte": {
      "types": "./dist/VegaChart.svelte.d.ts",
      "svelte": "./dist/VegaChart.svelte"
    },
    "./docs.mjs": "./docs.mjs",
    "./groups.doc.mjs": "./groups.doc.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "svelte-package",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck:docs": "node ../../scripts/check-svelte-docs.mjs .",
    "test": "vitest run --config vite.config.ts"
  },
  "dependencies": {
    "@astryxdesign/svelte": "workspace:*",
    "@astryxdesign/tokens": "workspace:*"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0",
    "vega": ">=6.0.0",
    "vega-lite": ">=6.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "5.56.4",
    "svelte-check": "^4.3.0",
    "typescript": "^6.0.3",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3"
  },
  "homepage": "https://github.com/oats7777/astryx-svelte#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oats7777/astryx-svelte.git",
    "directory": "packages/svelte-vega"
  },
  "bugs": {
    "url": "https://github.com/oats7777/astryx-svelte/issues"
  }
}
