{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": [
      "svelte"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "svelte.config.js"
  ]
}
